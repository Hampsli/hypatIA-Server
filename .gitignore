# ======================== #
# Java / Maven Project     #
# ======================== #

# Compiled class files
*.class

# Package Files & Archives
*.jar
*.war
*.ear
*.zip
*.tar.gz
*.rar
*.orig
*.bak

# Maven generated folders and files
/target/
pom.xml.tag
pom.xml.releaseBackup
pom.xml.versionsBackup
pom.xml.next
release.properties
dependency-reduced-pom.xml
build/
.mvn/wrapper/maven-wrapper.jar
.apt_generated/ # Annotation processing generated files

# ======================== #
# IDE specific files       #
# ======================== #

# IntelliJ IDEA
.idea/
*.iml
*.ipr
*.iws
out/
.project # Sometimes generated by older IDEA or mixed Eclipse/IDEA setups

# Eclipse
.classpath
.project
.settings/
bin/ # Old Eclipse compilation output folder

# VS Code
.vscode/ # Contains user settings, launch configs, sometimes sensitive info
.history/  # VS Code Local History

# NetBeans
nbproject/private/
build/
nbbuild/
dist/
nbdist/
.nb-gradle/
.nb_automatic_reload/

# ======================== #
# Operating System files   #
# ======================== #
.DS_Store
Thumbs.db
Desktop.ini

# ======================== #
# Logging & Cache          #
# ======================== #
*.log
log/
logs/ # Common directory for logs
tmp/  # Temporary files

# JVM crash logs
hs_err_pid*
replay_pid*

# Spring Boot specific
*.jks # Keystore files (often sensitive)
*.p12 # PKCS#12 Keystore files (often sensitive)
*.key # Private keys (sensitive)
*.crt # Certificates (can be public, but often generated in dev, safer to ignore)

# Spring Boot dev tools
.sts4-cache/ # Spring Tools Suite cache

# =============================================== #
# CRITICAL: Sensitive Configuration Files         #
# (DO NOT commit these to Git/GitHub)             #
# =============================================== #
# These files contain passwords, API keys, secrets,
# or environment-specific credentials.

# Ignore specific local application property files
application-*.properties # e.g., application-dev.properties, application-prod.properties IF they contain secrets.
application-local.properties
application-dev.properties
application-test.properties
application-prod.properties
application.properties # If it contains secrets or is entirely managed by environment variables/secrets manager
# If your primary application.properties will contain dev defaults, but sensitive
# values come from environment variables, you might NOT ignore application.properties
# but ensure it ONLY has placeholders like ${DB_PASSWORD}.

# YAML versions
application-*.yml
application-local.yml
application-dev.yml
application-test.yml
application-prod.yml
application.yml # Same considerations as .properties

# Environment variable files (e.g., used by Docker Compose or local scripts)
.env
.env.* # .env.local, .env.development etc.